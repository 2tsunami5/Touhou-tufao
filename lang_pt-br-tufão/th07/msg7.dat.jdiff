{
    "2": {
        "40_0": {
            "lines": [
                "Que sinal de boa sorte te encontrar aqui novamente."
            ]
        },
        "120_0": {
            "lines": [
                "Hoje, adivinha quem foi recém-possuída."
            ]
        },
        "210_0": {
            "lines": [
                "Estou novinha em folha!"
            ]
        },
        "300_0": {
            "lines": [
                "O quão muito estamos falando sobre 'recém-possuída'?"
            ]
        }
    },
    "0": {
        "60_0": {
            "lines": [
                "Para alguém que está se deslocando até o mundo dos mortos."
            ]
        },
        "61_0": {
            "lines": [
                "Os dias são entediantes se não tiver objetivos."
            ]
        },
        "61_1": {
            "lines": [
                "Hmm? Isso é inusitado."
            ]
        },
        "102_h1_0": {
            "lines": [
                "　　 Shikigami Yōkai Exímia 　　",
                "Ran Yakumo"
            ]
        },
        "102_0": {
            "lines": [
                "Não sabia que pessoas como você podiam andar por aqui."
            ]
        },
        "103_0": {
            "lines": [
                "O que você quer dizer com isso?"
            ]
        },
        "104_0": {
            "lines": [
                "Como pode ver",
                "Vermelho e branco, sinônimo de uma pessoa jubilosa."
            ]
        },
        "105_0": {
            "lines": [
                "De uma gata para uma raposa...",
                "Por acaso estamos no Reino Animal?"
            ]
        },
        "107_0": {
            "lines": [
                "Ah, é você a cruel pessoa que fez aquilo com a Chen.",
                "Você é humana, certo?"
            ]
        },
        "108_0": {
            "lines": [
                "Não estava lembrando."
            ]
        },
        "109_0": {
            "lines": [
                "Chen é a minha shikigami."
            ]
        },
        "110_0": {
            "lines": [
                "Agora ela se recuperou e está mais forte."
            ]
        },
        "111_0": {
            "lines": [
                "...Ela era forte?"
            ]
        },
        "112_0": {
            "lines": [
                "Espera um momento, shikigami?",
                "Não é você a shikigami?"
            ]
        },
        "113_0": {
            "lines": [
                "Eu também sou."
            ]
        },
        "114_0": {
            "lines": [
                "Minha Mestra ainda continua a dormir."
            ]
        },
        "115_0": {
            "lines": [
                "Como estava suspeitando, você é o objetivo."
            ]
        },
        "116_0": {
            "lines": [
                "Pois diga, o que queres?"
            ]
        },
        "117_0": {
            "lines": [
                "Quero restaurar a barreira entre o submundo",
                "e esse reino..."
            ]
        },
        "118_0": {
            "lines": [
                "Olhando mais de perto."
            ]
        },
        "119_0": {
            "lines": [
                "Seu objetivo principal se direciona à minha Mestra.",
                "Sim, entendi, esse é o intuito."
            ]
        },
        "120_0": {
            "lines": [
                "Minha Mestra ainda está hibernando."
            ]
        },
        "121_0": {
            "lines": [
                "Acorde ela."
            ]
        },
        "122_0": {
            "lines": [
                "Para te dar conhecimento, eu também sou a guardiã dela."
            ]
        },
        "123_0": {
            "lines": [
                "Não darei-lhe o direito de encontrar-se com minha mestra, ainda",
                "mais para a pessoa que fez algo cruel com minha shikigami."
            ]
        },
        "124_0": {
            "lines": [
                "Desta vez, Chen dará conta agora",
                "que está forte. Sofra com as consequências!"
            ]
        },
        "125_0": {
            "lines": [
                "A gata? Encontrei-me com ela agora há pouco..."
            ]
        },
        "126_0": {
            "lines": [
                "O que você disse?",
                "O que aconteceu com ela?"
            ]
        },
        "127_0": {
            "lines": [
                "Nada fora do comum."
            ]
        },
        "128_0": {
            "lines": [
                "Bem, a Chen ainda está se recuperando."
            ]
        },
        "129_0": {
            "lines": [
                "Ela tinha acabado de retornar."
            ]
        },
        "130_0": {
            "lines": [
                "Pelo visto, é a minha vez agora de eu fazer",
                "você pagar pelo que fez com a Chen."
            ]
        },
        "131_0": {
            "lines": [
                "Se eu derrotar a shikigami."
            ]
        },
        "132_0": {
            "lines": [
                "Será que a sua Mestra acorda de sua hibernação?"
            ]
        },
        "133_0": {
            "lines": [
                "Minha Mestra não acorda nem se fosse o fim do mundo."
            ]
        },
        "134_0": {
            "lines": [
                "hmm, está bem, por hora irei lidar",
                "com o obstáculo em minha frente."
            ]
        },
        "135_0": {
            "lines": [
                "Fique ciente de que meu poderio é diferente da Chen",
                "de múltiplas formas."
            ]
        }
    },
    "1": {
        "60_0": {
            "lines": [
                "É de se sonhar o requinte de uma shikigami se opor a uma",
                "sacerdotisa."
            ]
        },
        "61_0": {
            "lines": [
                "Acredito que meu talento possa ser o suficiente."
            ]
        },
        "62_0": {
            "lines": [
                "Gostei do truque～"
            ]
        },
        "63_0": {
            "lines": [
                "O que?"
            ]
        },
        "64_0": {
            "lines": [
                "E de imaginar que você era humana."
            ]
        },
        "65_0": {
            "lines": [
                "Mas eu sou."
            ]
        },
        "66_0": {
            "lines": [
                "Ah, quer saber, vou aproveitar esse momento",
                "E fazer você me apresentar para sua Mestra."
            ]
        },
        "67_0": {
            "lines": [
                "A Mestra Yukari ainda está dormindo."
            ]
        },
        "68_0": {
            "lines": [
                "E ela tem horário para acordar?",
                "Ou abrir os olhos?"
            ]
        },
        "69_0": {
            "lines": [
                "Mas já não é época de primavera?"
            ]
        },
        "70_0": {
            "lines": [
                "Não importa a época, a Mestra Yukari",
                "vive dormindo. O agora é um exemplo disso."
            ]
        },
        "71_0": {
            "lines": [
                "Mesmo não sendo de noite, vejo que está anoitecendo",
                "que não era para acontecer..."
            ]
        },
        "72_0": {
            "lines": [
                "Para a gente, o anoitecer é diferente.",
                "Em comparação ao seu."
            ]
        },
        "73_0": {
            "lines": [
                "A noite de verdade começa quando os humanos vão dormir."
            ]
        },
        "74_0": {
            "lines": [
                "Deixa de papinho e acorda ela."
            ]
        },
        "75_0": {
            "lines": [
                "Falando nisso, a Mestra Yukari nem está aqui～"
            ]
        },
        "76_0": {
            "lines": [
                "Isso aqui foi perda de tempo?"
            ]
        },
        "77_0": {
            "lines": [
                "E a perda foi por nada?"
            ]
        },
        "78_0": {
            "lines": [
                "E qual é o seu objetivo?"
            ]
        },
        "79_0": {
            "lines": [
                "Veja bem, apareceu um certo probleminha no submundo.",
                "E essa pessoinha possui um espírito familiar..."
            ]
        },
        "80_0": {
            "lines": [
                "Maneiro, meu objetivo era te derrotar."
            ]
        },
        "81_0": {
            "lines": [
                "Pooo~~"
            ]
        }
    },
    "12": {
        "40_0": {
            "lines": [
                "Que sinal de boa sorte te encontrar aqui novamente."
            ]
        },
        "120_0": {
            "lines": [
